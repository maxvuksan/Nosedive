# This .gitignore file is configured for Unity projects.

/[Ll]ibrary/
/[temp]/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Cc]ap_builds/
/[Cc]apture/[Bb]uild/
/[Cc]apture/[Rr]ecordings/
/[Ll]ogs/
/[Mm]emoryCaptures/
/[Uu]serSettings/

# Asset meta files for folders that are ignored
/[Ll]ibrary.meta
/[temp].meta
/[Oo]bj.meta
/[Bb]uild.meta
/[Bb]uilds.meta
/[Cc]ap_builds.meta
/[Cc]apture/[Bb]uild.meta
/[Cc]apture/[Rr]ecordings.meta
/[Ll]ogs.meta
/[Mm]emoryCaptures.meta
/[Uu]serSettings.meta

# Autogenerated IDE project files
ExportedObj/
.consulo/
.gradle/
AsmdefUtils/
/*.csproj
/*.unityproj
/*.sln
/*.suo
/*.tmp
/*.user
/*.userprefs
/*.pidb
/*.booproj
/*.svd
/*.pdb
/*.opendb
/*.IDelinkBackup

# Unity IDE configs
.vs/
.vs./
.idea/
.idea.*/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw*.bak
*.suo.meta

# Crashlytics generated file
crashlytics-build.properties

# Packed packages and tarballs
*.tgz

# Windows thumbnail caches
Thumbs.db
ehthumbs.db
[Dd]esktop.ini

# Mac system files
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Builds and Mobile platforms
/[Aa]rm64/
/[Aa]rm64.meta
/[Xx]64/
/[Xx]64.meta
/[Xx]86/
/[Xx]86.meta
